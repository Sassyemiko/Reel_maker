# .env.example
# Reels_maker Environment Configuration
# Copy this file to .env and edit as needed

# Background Videos Directory
REDDIT_VIDEOS_DIR=reels/videos

# Gameplay Videos Directory
GAMEPLAY_DIR=reels/videos

# LLM Model Path
LLM_MODEL_PATH=models/Meta-Llama-3-8B-Instruct-Q4_K_M.gguf

# Output Directories
FINAL_DIR=final
UPLOAD_FOLDER=uploads
AUDIO_DIR=audio
TEXTS_DIR=texts

# Flask Server Configuration
FLASK_PORT=5000
FLASK_DEBUG=true

# GPU Configuration (Optional)
# Set to 35 if you have NVIDIA GPU with 6GB+ VRAM
# Set to 0 for CPU-only
GPU_LAYERS=0

# Audio Configuration
TTS_VOICE=en-US-JennyNeural
AUDIO_SAMPLE_RATE=16000

# Video Configuration
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30